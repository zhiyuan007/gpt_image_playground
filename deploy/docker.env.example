# gpt_image_playground Docker 环境变量示例
# 复制本文件为自己的 .env 文件后再修改，避免把真实密码和密钥提交到公开仓库。

# 页面设置里默认显示的 API 地址。OpenAI 兼容接口通常需要填写到 /v1。
DEFAULT_API_URL=https://api.openai.com/v1

# 容器内置 API 代理实际转发到的上游 API 地址。仅在 ENABLE_API_PROXY=true 时生效。
API_PROXY_URL=https://api.openai.com/v1

# 是否开启同源 API 代理，用于解决浏览器跨域问题。可选值：true / false。
ENABLE_API_PROXY=false

# 是否强制锁定前端 API 代理开关。设为 true 后用户不能在页面里关闭代理。
LOCK_API_PROXY=false

# 是否只展示默认配置。适合公开部署时限制用户切换服务商或新增配置。
SHOW_DEFAULT_CONFIG_ONLY=false

# 容器内 Nginx 监听地址和端口。一般无需修改；对外端口由 docker -p 或 compose ports 控制。
HOST=0.0.0.0
PORT=80

# 后台托管生成权限密码。设置后，知道密码的用户才可以开启后台托管生成。
JOB_ACCESS_PASSWORD=change-this-password

# 后台托管登录 Cookie 签名密钥。生产环境必须固定为随机长字符串，否则服务重启后需要重新验证。
JOB_AUTH_SECRET=change-this-to-a-long-random-string

# 后台托管权限有效期，单位：小时。默认 168 小时，即 7 天。
JOB_AUTH_TTL_HOURS=168

# 后台托管生成结果临时保留时间，单位：小时。前端领取结果后会立即清理。
JOB_RESULT_TTL_HOURS=24

# 后台托管并发数。少数人使用建议保持 1，避免上游并发和服务器带宽被打满。
JOB_CONCURRENCY=1

# 后台托管最大排队数。超过后会返回“队列已满”。
JOB_MAX_PENDING=10

# 后台托管临时结果最大占用空间，单位：字节。默认 1 GiB。
JOB_MAX_STORAGE_BYTES=1073741824

# 后台托管结果下载限速，单位：字节/秒。384000 约等于 3 Mbit/s。
JOB_RESULT_RATE_LIMIT_BYTES_PER_SECOND=384000

# 后台托管参考图/遮罩请求体上限，单位：字节。默认 512 MiB。
JOB_MAX_IMAGE_INPUT_PAYLOAD_BYTES=536870912

# 后台托管允许请求的 API URL 白名单，多个地址用英文逗号分隔。通常必须填写完整 /v1 地址。
JOB_ALLOWED_BASE_URLS=https://api.ciyuanshen.top/v1,https://ciyuanshen.top/v1

# 后台任务数据目录。容器默认使用 /tmp，重启后进行中的内存任务仍会丢失。
JOB_DATA_DIR=/tmp/gpt-image-playground-jobs
